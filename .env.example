# === Binance API credentials ===
# Phase 3 (paper): create at https://testnet.binance.vision  (separate from main account)
# Phase 4 (live):  create in Binance account; enable READ + SPOT TRADE only, NO withdrawal; set IP whitelist
BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here
BINANCE_TESTNET=true

# === Mode: backtest | paper | live ===
# paper  -> requires BINANCE_TESTNET=true
# live   -> requires BINANCE_TESTNET=false
MODE=backtest

# === Universe / data ===
EXCHANGE=binance
PAIRS=BTC/USDT
TIMEFRAME=1d
STRATEGY=donchian

# === Indicator params (trend following) ===
EMA_TREND=200
ATR_PERIOD=14
ATR_STOP_MULT=2.0
DONCHIAN_ENTRY=20
DONCHIAN_EXIT=10

# === Confluence strategy params (alternative) ===
RSI_PERIOD=14
RSI_BUY=35
RSI_EXIT=55
REWARD_RISK=1.5

# === Risk (hard limits) ===
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=2
MAX_DAILY_LOSS_PCT=5
MAX_CONSECUTIVE_ERRORS=5
LIVE_CAPITAL_CAP=100
MAX_DRAWDOWN_PCT=25
MAX_TOTAL_EXPOSURE=3.0

# === Notifications (optional Telegram) ===
# 1) @BotFather -> /newbot -> copy the token here
# 2) message your bot, then run: python telegram_setup.py  to get the chat id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# === Mean-reversion / regime-switch params ===
BB_PERIOD=20
BB_STD=2.0
CHOP_PERIOD=14
CHOP_THRESHOLD=50
FUNDING_RATE_ESTIMATE=0.0001

# === Backtest realism ===
INITIAL_CAPITAL=400
TAKER_FEE_PCT=0.1
SLIPPAGE_BPS=5

# === Paths ===
STATE_PATH=data_store/state.json
LOG_DIR=logs
